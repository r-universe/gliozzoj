[submodule ".registry"]
	path = .registry
	url = https://github.com/gliozzoj/gliozzoj.r-universe.dev
	branch = HEAD
[submodule "NetInt"]
	path = NetInt
	url = https://github.com/GliozzoJ/NetInt
[submodule "clusterv"]
	path = clusterv
	url = https://github.com/AnacletoLAB/clusterv
[submodule "mosclust"]
	path = mosclust
	url = https://github.com/AnacletoLAB/mosclust
